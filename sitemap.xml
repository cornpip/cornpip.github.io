---
# Sitemap index replacing the jekyll-sitemap default (the gem skips generation
# when a source `sitemap.xml` exists). Points to one sitemap per language:
# each language's build enumerates only the pages it actually generated, so
# tag/category archives (whose names differ between ko and en posts) can never
# drift out of sync with reality. Built only into the default-language site.
layout: null
permalink: /sitemap.xml
lang-exclusive: ["ko-KR"]
---
<?xml version="1.0" encoding="UTF-8"?>
<sitemapindex xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <sitemap>
    <loc>{{ '/sitemap-ko.xml' | absolute_url | xml_escape }}</loc>
  </sitemap>
  <sitemap>
    <loc>{{ '/en/sitemap.xml' | absolute_url | xml_escape }}</loc>
  </sitemap>
</sitemapindex>
